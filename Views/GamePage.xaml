<Page
    x:Class="pacman.Views.GamePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
    KeyDown="OnKeyDown">

    <Grid x:Name="RootGrid" Background="Black" IsTabStop="True">
        
        <Viewbox>
            <Canvas x:Name="GameCanvas" Width="380" Height="420" Background="Black"/>
        </Viewbox>
        
        <TextBlock x:Name="ScoreText" Text="Score: 0" FontSize="20" FontFamily="Consolas" Foreground="White" Margin="10" VerticalAlignment="Top" HorizontalAlignment="Left"/>
        
        <TextBlock x:Name="LivesText" Text="Vidas: 3" FontSize="20" FontFamily="Consolas" Foreground="Yellow" Margin="10" VerticalAlignment="Top" HorizontalAlignment="Right"/>

        <Grid x:Name="MenuGrid" Background="#E6000000" Visibility="Visible">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/> <RowDefinition Height="*"/>    </Grid.RowDefinitions>

            <Image Grid.Row="0"
                   Source="ms-appx:///Assets/Images/logo.png" 
                   Width="360" 
                   HorizontalAlignment="Center" 
                   VerticalAlignment="Top"
                   Stretch="Uniform"
                   Margin="0,40,0,0"/>

            <StackPanel Grid.Row="1" 
                        VerticalAlignment="Center" 
                        HorizontalAlignment="Center" 
                        Spacing="20">
                
                <Button Content="INICIAR JOGO" Click="StartGame_Click" Width="200" Height="50" FontSize="18" FontWeight="Bold" Background="Yellow" Foreground="Black" CornerRadius="10"/>
                <Button Content="PLACAR (SCORES)" Click="ShowHighScores_Click" Width="200" Height="50" FontSize="18" FontWeight="Bold" Background="Blue" Foreground="White" CornerRadius="10"/>
                <Button Content="SAIR" Click="Exit_Click" Width="200" Height="50" FontSize="18" FontWeight="Bold" Background="Red" Foreground="White" CornerRadius="10"/>
                
            </StackPanel>
        </Grid>

        <Grid x:Name="HighScoreGrid" Background="#F2000000" Visibility="Collapsed">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="15">
                <TextBlock Text="MELHORES PONTUAÇÕES" FontSize="28" FontWeight="Bold" Foreground="Yellow" HorizontalAlignment="Center" Margin="0,0,0,20"/>
                
                <TextBlock x:Name="HighScoresListText" Text="A carregar pontuações..." FontSize="24" FontFamily="Consolas" Foreground="White" HorizontalAlignment="Center" TextAlignment="Center"/>

                <Button Content="VOLTAR" Click="BackToMenu_Click" Margin="0,30,0,0" Width="150" Background="Gray" Foreground="White" CornerRadius="5" HorizontalAlignment="Center"/>
            </StackPanel>
        </Grid>

    </Grid>
</Page>